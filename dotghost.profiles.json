{
    "core": {
        "description": "Default shared workflow layer for most repositories",
        "include": [
            "AGENTS.md",
            "CLAUDE.md",
            "agents/**",
            "commands/**",
            "workflows/**",
            "skills/**"
        ]
    },
    "onboarding": {
        "description": "Read-first profile for unfamiliar repositories and first safe changes",
        "include": [
            "AGENTS.md",
            "CLAUDE.md",
            "agents/explore.md",
            "agents/researcher.md",
            "commands/plan.md",
            "commands/review.md",
            "workflows/repo-first-change.md",
            "skills/repo-onboarding/**",
            "skills/testing/**",
            "skills/code-review/**"
        ]
    },
    "delivery": {
        "description": "Implementation, debugging, testing, and release-oriented workflows",
        "include": [
            "AGENTS.md",
            "CLAUDE.md",
            "agents/debugger.md",
            "agents/implementer.md",
            "agents/reviewer.md",
            "commands/**",
            "workflows/ship-a-bug-fix.md",
            "workflows/ship-a-feature.md",
            "skills/debugging/**",
            "skills/refactoring/**",
            "skills/release-management/**",
            "skills/reproduction/**",
            "skills/root-cause-analysis/**",
            "skills/testing/**"
        ]
    },
    "full": {
        "description": "Entire committed registry surface",
        "include": [
            "**/*"
        ]
    }
}